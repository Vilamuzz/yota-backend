APP_NAME=MyApp
APP_ENV=local
PORT=8080
DEBUG=true
DB=
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

SWAGGER_HOST=localhost:8080

CORS_ALLOW_ORIGIN=http://localhost:3000
FE_URL=http://localhost:3000

JWT_SECRET_KEY=supersecret
JWT_TTL=3600

TIMEOUT=5
LOG_TO_STDOUT=true
LOG_LEVEL=info        # debug | info | warn | error
LOG_FILE=             # optional: logs/app.log (empty = stdout only)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/oauth/google/callback

SESSION_SECRET=your-session-secret-key

RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=60

REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

S3_ENDPOINT=localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=yota-bucket
S3_USE_SSL=false
S3_REGION=us-east-1
S3_ROOT_USER=minioadmin
S3_ROOT_PASSWORD=minioadmin
CDN_BASE_URL=http://localhost:9000/yota-bucket

MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_ENVIRONMENT=sandbox